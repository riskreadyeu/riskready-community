# RiskReady Community Edition - Environment Configuration
# Copy this file to .env and adjust values as needed

# Database
POSTGRES_USER=riskready
POSTGRES_PASSWORD=change-me
POSTGRES_DB=riskready

# Authentication
JWT_SECRET=change-me-min-32-chars
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=change-me

# Session
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_SESSION_TTL_DAYS=14

# CORS -- leave empty to allow all origins (default).
# For production, restrict to your domain:
# CORS_ORIGIN=https://grc.yourdomain.com
CORS_ORIGIN=

# Cookie settings (set COOKIE_SECURE=true when using HTTPS)
COOKIE_DOMAIN=
COOKIE_SECURE=false
