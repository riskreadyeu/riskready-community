{
  "name": "riskready-community",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web",
    "apps/mcp-server-*",
    "gateway",
    "packages/*"
  ],
  "scripts": {
    "build:server": "npm run build -w apps/server",
    "build:web": "npm run build -w apps/web",
    "build:gateway": "npm run build -w gateway",
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "dev:gateway": "npm run dev -w gateway",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate -w apps/server"
  },
  "engines": {
    "node": ">=20"
  }
}
