{
  "name": "riskready-gateway",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "overrides": {
    "path-to-regexp": "8.4.1"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "rm -rf node_modules/.prisma/client node_modules/@prisma/client && mkdir -p node_modules/.prisma && ln -s ../../../apps/server/node_modules/.prisma/client node_modules/.prisma/client && ln -s ../../../apps/server/node_modules/@prisma/client node_modules/@prisma/client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.81.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@prisma/client": "7.6.0",
    "cron-parser": "^5.5.0",
    "fastify": "5.8.4",
    "pino": "10.3.1",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
