{
  "name": "riskready-gateway",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "overrides": {
    "path-to-regexp": "8.4.1"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "rm -rf node_modules/.prisma/client node_modules/@prisma/client && mkdir -p node_modules/.prisma && ln -s ../../../apps/server/node_modules/.prisma/client node_modules/.prisma/client && ln -s ../../../apps/server/node_modules/@prisma/client node_modules/@prisma/client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.74.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@prisma/client": "5.19.1",
    "cron-parser": "^5.5.0",
    "fastify": "5.8.2",
    "pino": "9.6.0",
    "yaml": "2.7.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "tsx": "4.21.0",
    "typescript": "5.5.4",
    "vitest": "3.0.0"
  }
}
