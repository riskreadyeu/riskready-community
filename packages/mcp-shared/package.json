{
  "name": "@riskready/mcp-shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "20.19.33",
    "typescript": "5.5.4",
    "vitest": "3.0.5"
  }
}
