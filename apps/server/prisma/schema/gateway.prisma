// Gateway models — chat conversations, messages, and memory

model ChatConversation {
  id             String        @id @default(cuid())
  title          String?
  model          String?
  userId         String
  organisationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([userId])
  @@index([organisationId])
  @@index([updatedAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String           @db.Text
  toolCalls      Json?
  actionIds      String[]         @default([])
  blocks         Json?
  inputTokens    Int?
  outputTokens   Int?
  model          String?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
}

model Memory {
  id             String                   @id @default(cuid())
  type           MemoryType
  content        String                   @db.Text
  tags           String[]                 @default([])
  source         String
  organisationId String
  userId         String?
  expiresAt      DateTime?
  search_vector  Unsupported("tsvector")?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organisationId])
  @@index([userId])
  @@index([type])
}

enum MemoryType {
  PREFERENCE
  CONTEXT
  KNOWLEDGE
}
