# RiskReady Server Environment Variables

# Required - JWT Configuration
JWT_SECRET=your-jwt-secret-min-32-chars-here

# Optional - Token TTL in seconds (default: 900 = 15 minutes)
ACCESS_TOKEN_TTL_SECONDS=900

# Required - Database URL (PostgreSQL)
DATABASE_URL=postgresql://riskready:your-database-password-here@localhost:5433/riskready

# Optional - Server Port (default: 4000)
PORT=4000

# Optional - CORS Origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional - Cookie Secure Flag (default: true in production, false otherwise)
COOKIE_SECURE=false

# Optional - Default admin account (created on first run if no users exist)
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=your-admin-password-here

# Optional - Encryption key for sensitive credentials (default: derived from JWT_SECRET)
# Recommended: Use a separate 32+ character key for credential encryption
# ENCRYPTION_KEY=your-encryption-key-min-32-chars
