{
  "name": "riskready-server",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "main": "dist/main.js",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "prisma generate --schema=prisma/schema && npx swc src -d dist --strip-leading-paths",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev": "ts-node-dev --respawn -r dotenv/config src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate --schema=prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:demo": "ts-node prisma/seed.ts",
    "seed:nexusguard": "ts-node prisma/seed-demo.ts",
    "import:risks": "ts-node prisma/seed/risks/import-risk-register.ts",
    "db:reset": "prisma migrate reset --force --schema=prisma/schema && npm run prisma:seed"
  },
  "dependencies": {
    "@nestjs/common": "11.1.11",
    "@nestjs/core": "11.1.11",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.11",
    "@nestjs/schedule": "6.1.0",
    "@nestjs/throttler": "6.5.0",
    "@prisma/client": "5.19.1",
    "axios": "1.13.2",
    "bcryptjs": "2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.6",
    "csv-parse": "6.1.0",
    "date-fns": "4.1.0",
    "express": "4.19.2",
    "helmet": "8.1.0",
    "jws": "4.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "xss": "1.0.15",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.14",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.7",
    "@types/express": "4.17.21",
    "@types/jest": "30.0.0",
    "@types/node": "25.3.3",
    "@types/passport-jwt": "4.0.1",
    "dotenv": "17.3.1",
    "jest": "30.2.0",
    "prisma": "7.4.2",
    "ts-jest": "29.4.6",
    "ts-node-dev": "2.0.0",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "xlsx": "0.18.5"
  }
}
